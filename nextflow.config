// nextflow.config - Optimized for Batch Cellpose Processing

params {
    // Input parameters
    input_image = null
    markers_csv = null
    outdir = './results'
    sample_name = 'large_sample'
    
    // Tiling parameters
    tile_size = 4096
    overlap = 512
    pyramid_level = 1  // Lower resolution for memory efficiency
    
    // MCMICRO workflow steps
    cellpose = true
    mcquant = true
    scimap = true
    
    // Cellpose-specific parameters
    dapi_channel = 8
    nuc_model = 'nuclei'
    nuc_diameter = 12
    nuc_flow_threshold = 0.3        // Add this
    nuc_cellprob_threshold = -1.0    // Add this (was implicitly -2)
    stitch_threshold = 0.0          // Add this
    cyto_model = 'cyto3'
    cyto_diameter = 28
    cyto_flow_threshold = 0.2
    cyto_cellprob_threshold = -2.0
    min_cell_size = 15
    cyto_batch_size = 8  // Cellpose internal batch size
    buffer_px = null     // Adaptive buffer

    // Cyto seg channel assignments
    // Option 1: Category-based (simple)
    // tumor_channels = '1,3'        // TOM channel
    // immune_channels = '2,6,9'     // CD45, CD3
    // tumor_weight = 0.55          // Total weight for tumor category
    // immune_weight = 0.45         // Total weight for immune category
    
    // Option 2: Per-channel custom weights (overrides categories if set)
    // Format: "channel:weight,channel:weight"
    // Example: "1:0.6,2:0.25,9:0.15" for TOM=0.6, CD45=0.25, CD3=0.15
    custom_channel_weights = '25:0.7,1:0.1,7:0.1,2:0.1'  // Leave empty to use category-based
    
    // BATCH OPTIMIZATION PARAMETERS
    nuclei_batch_size = 6        // Process 6 tiles per nuclei batch
    cyto_batch_size_tiles = 4    // Process 4 tiles per cyto batch
    
    // Container images
    cellpose_container = 'biocontainers/cellpose:3.0.1_cv1'
    mcquant_container = 'labsyspharm/quantification:latest'
    scimap_container = 'labsyspharm/scimap:0.17.7'
    
    // Resource limits
    max_memory = '60.GB'
    max_cpus = 18
    max_time = '48.h'

// QC parameters - LENIENT for immune-rich tissue
    cylinter = false  // Disable aggressive QC by default
    
    min_cell_area = 20         // Very small - capture lymphocytes
    max_cell_area = 5000       // Large - capture macrophages
    max_eccentricity = 0.95    // Very lenient
    min_marker_expression = 5  // Low threshold
    fold_window = 100          // For fold detection
    fold_cv_threshold = 2.0    // High = less filtering

    background_subtract = true
    bg_percentile = 5  // MCMICRO standard

    global_bg_subtract = false
    bg_method = 'rolling_ball'
    bg_radius = 50
}

// Process configuration
process {
    // Default resources
    cpus = 1
    memory = 4.GB
    time = 8.h
    
    // Container engine
    container = 'mcmicro-tiles:latest'
    
    // Process-specific configurations
    withName:TILE_LARGE_IMAGE {
        cpus = 18
        memory = 60.GB  // High memory for large image processing
        time = 6.h
        container = 'mcmicro-tiles:latest'
    }
    
    withName:BACKGROUND_SUBTRACT {
        cpus = 4
        memory = 8.GB  // High memory for large image processing
        maxForks = 8
        time = 4.h
    }

    // BATCH CELLPOSE PROCESSES - OPTIMIZED PARALLEL EXECUTION
    withName:RUN_CELLPOSE_NUCLEI_BATCH {
        cpus = 4
        memory = 16.GB     // More memory for batch processing
        time = 36.h
        maxForks = 3       // Allow 2 nuclei batches to run concurrently
        container = params.cellpose_container
    }
    
    withName:CREATE_MEMBRANE_COMPOSITES {
        cpus = 4
        memory = 8.GB
        time = 2.h
        maxForks = 4
        container = 'mcmicro-tiles:latest'
    }

    withName:RUN_CELLPOSE_CYTO_SEEDED {
        cpus = 8
        memory = 16.GB     // Higher memory for cyto batch processing
        time = 48.h
        maxForks = 2       // Sequential cyto processing (more GPU memory intensive)
        container = params.cellpose_container
    }
    
    withName:RUN_MCQUANT {
        cpus = 2
        memory = 5.GB
        time = 36.h
        maxForks = 10       // High parallelization for MCQuant (no GPU needed)
        container = params.mcquant_container
    }
    
    withName:STITCH_RESULTS {
        cpus = 16
        memory = 32.GB
        time = 6.h
        container = 'mcmicro-tiles:latest'
    }

    withName:CYLINTER_QC {
        cpus = 16
        memory = 40.GB
        time = 4.h
    }

    withName:SPATIAL_ANALYSIS {
        cpus = 16
        memory = 32.GB
        time = 8.h
        container = params.scimap_container
    }
}

// Executor configuration
executor {
    name = 'local'
    cpus = params.max_cpus
    memory = params.max_memory
    queueSize = 300     // Higher queue for batch processing
}

// Docker configuration
docker {
    enabled = true
    // Mount all necessary paths including WSL mounts and work directory
    runOptions = '--gpus all --shm-size=16g -v /mnt:/mnt -v ${PWD}/cellpose_models:/tmp/cellpose_models'
    //runOptions = '-u $(id -u):$(id -g) --gpus all --shm-size=16g -v /mnt:/mnt -v ${PWD}/cellpose_models:/tmp/cellpose_models'
}

// Singularity configuration (alternative)
singularity {
    enabled = false
    autoMounts = true
}

// Report configuration
report {
    enabled = true
    file = "${params.outdir}/batch_pipeline_report.html"
    overwrite = true
}

timeline {
    enabled = true
    file = "${params.outdir}/batch_timeline.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.outdir}/batch_trace.txt"
    overwrite = true
}

dag {
    enabled = true
    file = "${params.outdir}/batch_flowchart.html"
    overwrite = true
}

// Work directory cleanup - DISABLED for stability on mounted drives
cleanup = false

// Resume configuration
resume = true