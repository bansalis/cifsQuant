// nextflow.config - cifsQuant pipeline configuration

manifest {
    name            = 'cifsQuant'
    description     = 'End-to-end spatial quantification pipeline for cyclic immunofluorescence data'
    mainScript      = 'mcmicro-tiled.nf'
    nextflowVersion = '>=23.10.0'
    version         = '1.0.0'
}

params {
    // Input/output
    input_image  = null
    markers_csv  = null
    outdir       = './results'
    sample_name  = 'sample'

    // Tiling
    tile_size    = 4096
    overlap      = 512
    pyramid_level = 1

    // Pipeline steps
    cellpose = true
    mcquant  = true
    scimap   = true

    // Cellpose - nuclei
    dapi_channel           = 0         // 0-indexed channel index for DAPI
    nuc_model              = 'nuclei'
    nuc_diameter           = 12
    nuc_flow_threshold     = 0.3
    nuc_cellprob_threshold = -1.0
    stitch_threshold       = 0.0

    // Cellpose - cytoplasm
    cyto_model              = 'cyto2'
    cyto_diameter           = 28
    cyto_flow_threshold     = 0.2
    cyto_cellprob_threshold = -2.0
    min_cell_size           = 15
    cyto_batch_size         = 8

    // Cytoplasm channel weights (per-channel, overrides category-based)
    // Format: "channel_index:weight,channel_index:weight"
    // Example for 3-channel composite: "0:0.6,1:0.25,2:0.15"
    // Set to '' to use equal weighting
    custom_channel_weights = ''

    // Batch processing
    nuclei_batch_size    = 6
    cyto_batch_size_tiles = 4

    // Container images
    cellpose_container = 'biocontainers/cellpose:3.0.1_cv1'
    mcquant_container  = 'labsyspharm/quantification:latest'
    scimap_container   = 'labsyspharm/scimap:0.17.7'

    // Resource limits (adjust to your hardware)
    max_memory = '60.GB'
    max_cpus   = 18
    max_time   = '48.h'

    // Cell QC thresholds
    cylinter            = false
    min_cell_area       = 20
    max_cell_area       = 5000
    max_eccentricity    = 0.95
    min_marker_expression = 5

    // Background correction (disabled by default)
    background_subtract = false
    bg_percentile       = 5
}

process {
    cpus      = 1
    memory    = 4.GB
    time      = 8.h
    container = 'mcmicro-tiles:latest'

    withName:TILE_LARGE_IMAGE {
        cpus      = 18
        memory    = 60.GB
        time      = 6.h
        container = 'mcmicro-tiles:latest'
    }

    withName:BACKGROUND_SUBTRACT {
        cpus     = 4
        memory   = 6.GB
        maxForks = 4
        time     = 4.h
    }

    withName:RUN_CELLPOSE_NUCLEI_BATCH {
        cpus      = 8
        memory    = 28.GB
        time      = 36.h
        maxForks  = 2
        container = params.cellpose_container
    }

    withName:CREATE_MEMBRANE_COMPOSITES {
        cpus      = 4
        memory    = 8.GB
        time      = 2.h
        maxForks  = 4
        container = 'mcmicro-tiles:latest'
    }

    withName:RUN_CELLPOSE_CYTO_SEEDED {
        cpus      = 8
        memory    = 28.GB
        time      = 48.h
        maxForks  = 2
        container = params.cellpose_container
    }

    withName:RUN_MCQUANT {
        cpus      = 4
        memory    = 10.GB
        time      = 36.h
        maxForks  = 5
        container = params.mcquant_container
    }

    withName:STITCH_RESULTS {
        cpus      = 16
        memory    = 48.GB
        time      = 50.h
        container = 'mcmicro-tiles:latest'
    }

    withName:SPATIAL_ANALYSIS {
        cpus      = 16
        memory    = 32.GB
        time      = 8.h
        container = params.scimap_container
    }
}

executor {
    name      = 'local'
    cpus      = params.max_cpus
    memory    = params.max_memory
    queueSize = 300
}

docker {
    enabled    = true
    runOptions = '--gpus all --shm-size=16g -v /mnt:/mnt'
}

singularity {
    enabled    = false
    autoMounts = true
}

report {
    enabled   = true
    file      = "${params.outdir}/pipeline_report.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_timeline.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_trace.txt"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_dag.html"
    overwrite = true
}

cleanup = false
resume  = true
